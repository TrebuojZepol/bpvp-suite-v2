{
  "name": "@bpvp/wallet",
  "version": "0.0.0",
  "private": true,
  "description": "BPVP institutional desktop wallet (Electron + React)",
  "author": "BPVP",
  "type": "module",
  "main": "desktop/main.mjs",
  "scripts": {
    "predev": "node scripts/build-main.mjs",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && BPVP_WALLET_DEV=1 electron .\"",
    "build": "vite build && node scripts/build-main.mjs",
    "start": "electron .",
    "pack": "vite build && node scripts/build-main.mjs && electron-builder",
    "test": "node -e \"console.log('[wallet] unit tests not configured yet')\"",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/secp256k1": "^1.7.1",
    "argon2": "^0.41.1",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.7",
    "bitcoinjs-message": "^2.2.0",
    "ecpair": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.15",
    "react-router-dom": "^7.1.1",
    "tiny-secp256k1": "^2.2.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
