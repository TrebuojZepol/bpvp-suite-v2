# Copy to `.env` in this directory (`infra/docker/.env`). Never commit `.env`.
# All secrets below are REQUIRED — docker compose will fail if any are missing or empty.

# -----------------------------------------------------------------------------
# PostgreSQL (postgres:16-alpine)
# Database name is fixed to `bpvp_suite` in docker-compose.yml.
# -----------------------------------------------------------------------------
POSTGRES_USER=bpvp
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Redis (redis:7-alpine)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Bitcoin Core — signet only (RPC not exposed to host). RPC port inside the stack: 39332.
# -----------------------------------------------------------------------------
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
